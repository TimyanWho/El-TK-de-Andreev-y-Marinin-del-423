<Window x:Class="RailwayFareCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Стоимость проезда железнодорожным транспортом"
        Width="760" Height="460"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Расчет стоимости проезда"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#222"
                   Margin="0,0,0,12"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="1.7*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,10,0" BorderBrush="#D0D0D0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Расстояние (км):" VerticalAlignment="Center" Margin="0,0,12,12"/>
                    <TextBox x:Name="DistanceTextBox" Grid.Row="0" Grid.Column="1" Height="30" MinWidth="160" Margin="0,0,0,12" Padding="8,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Количество билетов:" VerticalAlignment="Center" Margin="0,0,12,12"/>
                    <TextBox x:Name="TicketsTextBox" Grid.Row="1" Grid.Column="1" Height="30" MinWidth="160" Margin="0,0,0,12" Padding="8,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Базовая ставка:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="8 руб. за 1 км" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="16" Margin="10,0,0,0" BorderBrush="#D0D0D0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Комфортабельность" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <RadioButton x:Name="PlatskartRadioButton" Content="Плацкарт" IsChecked="True" Margin="0,4"/>
                    <RadioButton x:Name="CoupeRadioButton" Content="Купе" Margin="0,4"/>
                    <RadioButton x:Name="PolulyuksRadioButton" Content="Полулюкс" Margin="0,4"/>
                    <RadioButton x:Name="LyuksRadioButton" Content="Люкс" Margin="0,4"/>
                    <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#555"
                               Text="Коэффициенты: плацкарт 100%, купе +10%, полулюкс +20%, люкс +30%."/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="16" Margin="0,14,0,14" BorderBrush="#D0D0D0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Стоимость билетов с учетом комфортабельности:" FontWeight="Bold" VerticalAlignment="Top" Margin="0,0,12,0"/>
                <TextBlock x:Name="ResultTextBlock" Grid.Column="1" Text="Введите данные и нажмите кнопку &quot;Вычислить&quot;."
                           TextWrapping="Wrap" FontSize="15" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <Button Grid.Row="3"
                x:Name="CalculateButton"
                Content="Вычислить"
                Width="150"
                Height="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="#2D6CDF"
                Foreground="White"
                FontWeight="Bold"
                BorderThickness="0"
                Click="CalculateButton_Click"/>
    </Grid>
</Window>
